{
  "dns": {
    "strategy": "ipv4_only",
    "servers": [
      {"tag": "bootstrap"},
      {"tag": "local"},
      {"tag": "remote_cf"},
      {"tag": "fallback"}
    ],
    "rules": [
      { "rule_set": ["geosite-cn"], "server": "local" }
    ]
  },
  "route": {
    "rules": [
      { "action": "hijack-dns", "protocol": ["dns"] },
      { "action": "hijack-dns", "port": [53] },
      { "rule_set": ["geosite-cn", "geoip-cn"], "outbound": "direct" },
      { "outbound": "proxy" }
    ]
  }
}
